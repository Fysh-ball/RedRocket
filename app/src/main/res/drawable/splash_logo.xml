<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12 SplashScreen icon safe zone: 288dp canvas, inner 192dp visible
  circle. Inset = (288 - 160) / 2 = 64dp on each side to leave comfortable
  margin so the "Red Rocket" text and rocket tips are not clipped by the mask.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/red_rocket_logo"
    android:insetLeft="52dp"
    android:insetRight="52dp"
    android:insetTop="52dp"
    android:insetBottom="52dp" />
